# Gateway Configuration
PORT=8000
NODE_ENV=development

# Authentication
JWT_SECRET=nexus_super_secret_key_change_in_prod

# Base URL (Postgres container running on port 5432)
BASE_DATABASE_URL="postgresql://nexusedu_user:nexusedu_password@localhost:5432/nexusedu"

# Service-Specific Database Connections (using ?schema param to isolate schemas)
AUTH_DATABASE_URL="${BASE_DATABASE_URL}?schema=auth"
ACADEMIC_DATABASE_URL="${BASE_DATABASE_URL}?schema=academic"
FINANCE_DATABASE_URL="${BASE_DATABASE_URL}?schema=finance"
LIBRARY_DATABASE_URL="${BASE_DATABASE_URL}?schema=library"
STUDENT_AFFAIRS_DATABASE_URL="${BASE_DATABASE_URL}?schema=student_affairs"

# RabbitMQ
RABBITMQ_URL="amqp://nexusedu_user:nexusedu_password@localhost:5672"