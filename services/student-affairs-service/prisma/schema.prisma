generator client {
  provider = "prisma-client"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

// Legacy mapped DB for SOAP Service
model Attendance {
  id            String   @id @default(uuid())
  nim           String
  courseId      String
  semester      String
  date          DateTime
  status        String   // PRESENT, ABSENT, EXCUSED, SICK
  createdAt     DateTime @default(now())

  @@map("attendance_legacy")
}

model Violation {
  id          String   @id @default(uuid())
  nim         String
  date        DateTime @default(now())
  type        String
  description String
  severity    String   // LOW, MEDIUM, HIGH, CRITICAL
  status      String   @default("ACTIVE") // ACTIVE, RESOLVED, APPEALING
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("violations_legacy")
}

// New DB table for REST Service
model CounselingSession {
  id             String   @id @default(uuid())
  studentNim     String
  date           DateTime
  status         String   @default("SCHEDULED") // SCHEDULED, COMPLETED, CANCELLED
  counselorNotes String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("counseling_sessions")
}
